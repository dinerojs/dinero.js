{
  "compilerOptions": {
    "types": ["vitest/globals"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": false,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "target": "ESNEXT",
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "dinero.js": ["packages/dinero.js/src/index"],
      "dinero.js/currencies": ["packages/dinero.js/src/currencies/index"],
      "dinero.js/bigint": ["packages/dinero.js/src/bigint/index"],
      "@dinerojs/react": ["packages/react/src/index"],
      "@dinerojs/react/bigint": ["packages/react/src/bigint/index"],
      "@dinerojs/react/server": ["packages/react/src/server/index"],
      "test-utils": ["test/utils/index"]
    }
  },
  "exclude": [
    "**/dist",
    "**/lib",
    "**/temp",
    "**/node_modules",
    "docs",
    "examples"
  ]
}
