{
  "extends": [
    "config:js-lib",
    "schedule:monthly",
    ":semanticCommitTypeAll(chore)",
    ":preserveSemverRanges"
  ],
  "timezone": "Europe/Paris",
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["security"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "description": "Group Vite and Vitest packages together",
      "matchPackageNames": ["vite", "vitest", "@vitest/**"],
      "groupName": "vite"
    }
  ]
}
